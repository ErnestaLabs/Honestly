# ────────────────────────────────────────────────────────
# Honestly — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to version control.
# ────────────────────────────────────────────────────────

# ── Telegram ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
ARENA_SUPERGROUP_ID=-1001234567890

# ── API Keys ────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
PEXELS_API_KEY=your_pexels_api_key
STREETDATA_KEY=your_streetdata_key
PATMA_KEY=your_patma_key
PROPERTYDATA_KEY=your_propertydata_key

# ── Feature flags ───────────────────────────────────────
PATMA_ENRICH=1
STREETDATA_ENRICH=1

# ── Postgres / PostGIS (Docker compose overrides these for internal connections) ──
POSTGRES_USER=honestly
POSTGRES_PASSWORD=change_this_to_a_strong_password
POSTGRES_DB=honestly
# External connection string (used by the app when NOT running inside Docker)
DATABASE_URL=postgresql://honestly:change_this_to_a_strong_password@localhost:5432/honestly

# ── Redis ───────────────────────────────────────────────
# Docker compose overrides this for internal connections
REDIS_URL=redis://localhost:6379/0

# ── Currency ────────────────────────────────────────────
# £1 GBP = 50 XTR (Telegram Stars). Do not change unless Telegram updates their rate.
GBP_TO_XTR=50

# ── CORS (comma-separated origins) ──────────────────────
CORS_ORIGINS=https://usehonestly.co.uk,https://t.me,https://web.telegram.org

# ── Backend URL (for invoice links, etc.) ───────────────
HONESTLY_PUBLIC_URL=https://usehonestly.co.uk
HONESTLY_WEBAPP_URL=https://usehonestly.co.uk

# ── Optional: SMTP for email funnel ─────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@usehonestly.co.uk
