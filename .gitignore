# Secrets - never commit
.env
.env.*
*.key
*.pem
secrets*.json
.vps_secret
.vps_pw
.vps_*
.hmlr_query_token

# Editor/tool scratch snapshots (e.g. bot.py.tmp.1560.<hash>)
*.tmp.*

# Persistence DB (store.py) - runtime data, never committed (training + legal live on the VPS)
*.db
*.db-wal
*.db-shm
honestly.db

# Working/temp files
_*.py
_*.json
_*.html
_*.txt
_PRIVATE_*

# Generated report/media artifacts - keep the data, not the rendered outputs
*.pdf
*.html
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.mp3
*.mp4

# Generated analysis / publish outputs
graphify-out/
.understand-anything/
preview/
out/
_edgetmp/
site/

# Paid-ad bookings (ads.py) - live commercial inventory, never committed; ads.example.json is the schema
ads.json

# Generated intermediates (keep the .md sources + final .pdf)
*_appraisal.html

# Bot runtime state + scratch images
entitlements.json
testimonials.json
testimonials/
_frontage.jpg
_route.png

# Logs
*.log

# Python caches
__pycache__/
*.pyc
.pytest_cache/
.gstack/
cache/

# Browser profile used by render/screenshot tooling - can hold cookies/tokens, never commit
site/_cprofile/
_cprofile/

# Real module that the _*.py rule would otherwise hide (MCP seam used by reddit_intel.py)
!_hit_sdk.py
