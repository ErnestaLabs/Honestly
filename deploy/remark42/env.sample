# Remark42 config template - safe to commit. Copy to .env and fill in real values.
#   cp env.sample .env

# Served under the existing domain at /remark42/ - no new subdomain, DNS or cert needed.
REMARK_URL=https://usehonestly.co.uk/remark42
SITE=honestly
SECRET=__GENERATE__   # python3 -c "import secrets; print(secrets.token_urlsafe(48))"

AUTH_ANON=true

AUTH_TELEGRAM=true
TELEGRAM_TOKEN=__DEDICATED_COMMENTS_BOT_TOKEN__   # @usehonestly_comments_bot

STORE_BOLT_PATH=/srv/var/db
BACKUP_PATH=/srv/var/backup
